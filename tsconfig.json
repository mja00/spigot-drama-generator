{
    "compilerOptions": {
        "target": "es2022",
        "module": "es2022",
        "moduleResolution": "bundler",
        "lib": ["es2022"],
        "types": ["@cloudflare/vitest-pool-workers"],
        "noEmit": true,
        "strict": true,
        "noUncheckedIndexedAccess": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "verbatimModuleSyntax": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*",
        "test/**/*",
        "worker-configuration.d.ts",
        "vitest.config.ts"
    ]
}
